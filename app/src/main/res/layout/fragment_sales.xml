<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/text_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="매출 데이터"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layout_sales_subtabs"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/pill_bg"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tab_sales_vmms"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/order_subtab_selected_bg"
            android:gravity="center"
            android:text="VMMS"
            android:textColor="#1E4FA3"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_sales_easyshop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="EasyShop"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_vmms_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_today_pie_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="3dp"
            android:background="@drawable/pill_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="2026.02.12"
            android:textSize="12sp" />

        <com.example.vmmswidget.ui.TodayPieChartView
            android:id="@+id/today_pie_chart"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="0dp" />

        <TextView
            android:id="@+id/text_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/pill_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="2026.02.03 - 2026.02.09"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/text_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="총 0 원"
            android:textColor="#1E4FA3"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.example.vmmswidget.ui.SalesChartView
            android:id="@+id/sales_chart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:overScrollMode="ifContentScrolls" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_easyshop_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_easyshop_pie_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="3dp"
            android:background="@drawable/pill_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="2026.02.12"
            android:textSize="12sp" />

        <com.example.vmmswidget.ui.TodayCompareBarChartView
            android:id="@+id/easyshop_compare_chart"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="0dp" />

        <TextView
            android:id="@+id/text_easyshop_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:background="@drawable/pill_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="2026.02.03 - 2026.02.09"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/text_easyshop_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="총 0 원"
            android:textColor="#1E4FA3"
            android:textSize="22sp"
            android:textStyle="bold" />

        <com.example.vmmswidget.ui.SalesChartView
            android:id="@+id/easyshop_sales_chart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:overScrollMode="ifContentScrolls" />

        <TextView
            android:id="@+id/text_easyshop_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="EasyShop 데이터가 없습니다."
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
