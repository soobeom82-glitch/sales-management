<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:foreground="@drawable/transaction_row_bg"
    android:padding="8dp">

    <TextView
        android:id="@+id/col_easy_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:gravity="center"
        android:text="2/24 10:38"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/col_easy_terminal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="center"
        android:text="A4100"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/col_easy_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="center"
        android:text="체크"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/col_easy_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="end"
        android:text="3,000원"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/col_easy_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="center"
        android:text="승인"
        android:textSize="12sp" />

</LinearLayout>
