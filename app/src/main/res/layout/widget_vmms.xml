<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg">

    <!-- Left: sales info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="VMMS 최신"
            android:textColor="#334155"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="데이터 없음"
            android:textColor="#334155"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/widget_easyshop_amount_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_sales_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="매출"
                    android:textColor="#334155"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_sales_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0원"
                    android:textColor="#334155"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_deposit_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_deposit_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="입금"
                    android:textColor="#334155"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_deposit_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0원"
                    android:textColor="#334155"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Middle: chart -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/widget_chart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:contentDescription="7일 매출 그래프" />

        <TextView
            android:id="@+id/widget_avg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:fontFamily="sans-serif-medium"
            android:text="avg. 0원"
            android:textColor="#334155"
            android:singleLine="true"
            android:ellipsize="end"
            android:textSize="11sp" />
    </FrameLayout>

    <!-- Order badge -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_order_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="발주"
            android:textSize="11sp"
            android:textColor="#334155" />

        <TextView
            android:id="@+id/widget_order_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_order_badge_bg"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Right: refresh + time -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="새로고침"
            android:src="@android:drawable/ic_popup_sync" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="4dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="--:--:--"
            android:textColor="#334155"
            android:textSize="11sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

</LinearLayout>
