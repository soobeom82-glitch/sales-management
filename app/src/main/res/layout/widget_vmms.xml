<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg">

    <!-- Left: sales info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="VMMS 최신"
            android:textColor="#334155"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="데이터 없음"
            android:textColor="#334155"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- Middle: chart -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="4"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/widget_chart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:contentDescription="7일 매출 그래프" />

        <TextView
            android:id="@+id/widget_avg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:fontFamily="sans-serif-medium"
            android:text="avg. 0원"
            android:textColor="#334155"
            android:singleLine="true"
            android:ellipsize="end"
            android:textSize="10sp" />
    </FrameLayout>

    <!-- Order badge -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_order_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="발주"
            android:textSize="10sp"
            android:textColor="#334155" />

        <TextView
            android:id="@+id/widget_order_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_order_badge_bg"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Right: refresh + time -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="새로고침"
            android:src="@android:drawable/ic_popup_sync" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="4dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="--:--:--"
            android:textColor="#334155"
            android:textSize="11sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

</LinearLayout>
