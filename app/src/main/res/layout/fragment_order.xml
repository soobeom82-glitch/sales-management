<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layout_order_subtabs"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/pill_bg"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tab_order"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/order_subtab_selected_bg"
            android:gravity="center"
            android:textSize="14sp"
            android:text="발주"
            android:textColor="#1E4FA3"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_order_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:textSize="14sp"
            android:text="이력"
            android:textColor="#6B7280"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_order_planned"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_order_planned_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="발주 예정"
                android:textColor="#666666"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/button_clear_planned"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:background="@drawable/order_item_bubble"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="비우기"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/button_submit_order"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/order_item_bubble"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="발주"
                android:textColor="#1E4FA3"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/order_planned_box_bg"
            android:minHeight="72dp"
            android:orientation="vertical"
            android:padding="10dp">

            <com.example.vmmswidget.ui.SimpleFlowLayout
                android:id="@+id/planned_items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="2dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_order_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/text_order_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="발주 품목"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/button_add_category"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:gravity="center"
            android:background="@drawable/order_item_bubble"
            android:text="+"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1E4FA3" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_order_tree"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/layout_order_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EFF3F8"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:gravity="center"
                android:text="시간"
                android:textStyle="bold"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="6"
                android:gravity="center"
                android:text="항목"
                android:textStyle="bold"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="비고"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_order_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/text_order_history_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="발주 이력이 없습니다."
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
