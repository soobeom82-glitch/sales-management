<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/transactions_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="거래 내역"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/transactions_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="최근 거래 내역"
            android:textSize="12sp"
            android:textColor="#666666" />

        <Button
            android:id="@+id/transactions_request_code"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:text="승인번호요청"
            android:textSize="11sp"
            android:background="@drawable/btn_close"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/transactions_search_row"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:background="#EFF2F6"
        android:foreground="@drawable/transaction_row_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="찾기"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="8"
            android:layout_marginStart="6dp"
            android:background="@drawable/search_bubble_bg"
            android:paddingStart="8dp"
            android:paddingEnd="6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp">

            <EditText
                android:id="@+id/transactions_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="검색어 입력"
                android:inputType="number"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:paddingEnd="22dp"
                android:textColor="#666666"
                android:textColorHint="#666666"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/transactions_search_clear"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical|end"
                android:text="X"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#666666"
                android:alpha="0.6"
                android:contentDescription="검색어 지우기" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/transactions_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#EFF2F6"
        android:foreground="@drawable/transaction_row_bg"
        android:padding="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="시간"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:text="판매 항목"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="카드번호"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="금액"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/transactions_swipe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/transactions_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/transactions_bottom_progress"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/transactions_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="최근 거래 내역이 없습니다."
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" />
</LinearLayout>
